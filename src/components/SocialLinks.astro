---
interface SocialLink {
  name: string;
  url: string;
  icon: string;
}

const socialLinks: SocialLink[] = [
  {
    name: 'GitHub',
    url: 'https://github.com/',
    icon: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
  },
  {
    name: '掘金',
    url: 'https://juejin.cn/',
    icon: '<path d="M2 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2V3z"/><path d="M12 7h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8V7z"/><path d="M7 17l5 4 5-4"/>',
  },
  {
    name: '知乎',
    url: 'https://www.zhihu.com/',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/>',
  },
  {
    name: '微博',
    url: 'https://weibo.com/',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>',
  },
  {
    name: '微信公众号',
    url: '#',
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  },
];
---

<div class="flex items-center gap-3">
  {socialLinks.map(({ name, url, icon }) => (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="w-9 h-9 flex items-center justify-center rounded-lg text-text-muted hover:text-primary hover:bg-primary/5 transition-colors"
      title={name}
      aria-label={name}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
    </a>
  ))}
</div>
