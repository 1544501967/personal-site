---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const allTags = [...new Set(allProjects.flatMap(({ data }) => data.tags))];
---

<BaseLayout title="项目 - Daniel" description="我的项目作品集。">
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold mb-2">项目</h1>
        <p class="text-text-muted mb-8">我参与和创建的项目作品。</p>

        <!-- Filter Tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          <button
            class="tag bg-primary text-white cursor-pointer"
            data-filter="all"
          >
            全部
          </button>
          {allTags.map((tag) => (
            <button class="tag cursor-pointer hover:bg-primary hover:text-white transition-colors" data-filter={tag}>
              {tag}
            </button>
          ))}
        </div>

        <!-- Projects Grid -->
        <div class="grid md:grid-cols-2 gap-6" id="projects-grid">
          {projects.map((project) => (
            <div
              class="card overflow-hidden group"
              data-tags={project.data.tags.join(',')}
            >
              {project.data.image ? (
                <div class="aspect-video bg-gradient-to-br from-primary/10 to-primary-light/10 flex items-center justify-center">
                  <span class="text-5xl font-bold text-primary/15">{project.data.title.charAt(0)}</span>
                </div>
              ) : (
                <div class="aspect-video bg-gradient-to-br from-primary/5 to-primary-light/5 flex items-center justify-center">
                  <span class="text-5xl font-bold text-primary/15">{project.data.title.charAt(0)}</span>
                </div>
              )}
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h3 class="font-semibold text-lg mb-2">{project.data.title}</h3>
                <p class="text-text-muted text-sm leading-relaxed mb-4">
                  {project.data.description}
                </p>
                <div class="flex items-center gap-4">
                  {project.data.github && (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-text-muted hover:text-primary transition-colors flex items-center gap-1.5"
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                      源码
                    </a>
                  )}
                  {project.data.demo && (
                    <a
                      href={project.data.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-text-muted hover:text-primary transition-colors flex items-center gap-1.5"
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      演示
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll('[data-filter]');
  const projectCards = document.querySelectorAll('#projects-grid > div');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      filterButtons.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white');
      });
      btn.classList.add('bg-primary', 'text-white');

      projectCards.forEach((card) => {
        const tags = card.getAttribute('data-tags') ?? '';
        if (filter === 'all' || tags.split(',').includes(filter!)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
