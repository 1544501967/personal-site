---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const allTags = [...new Set(allProjects.flatMap(({ data }) => data.tags))];

const categoryMap: Record<string, string> = {
  work: '工作项目',
  personal: '个人项目',
  opensource: '开源项目',
};

const statusMap: Record<string, { label: string; color: string }> = {
  planning: { label: '规划中', color: 'bg-gray-100 text-gray-600' },
  'in-progress': { label: '进行中', color: 'bg-blue-50 text-blue-600' },
  completed: { label: '已完成', color: 'bg-green-50 text-green-600' },
  archived: { label: '已归档', color: 'bg-gray-100 text-gray-500' },
};
---

<BaseLayout title="项目 - Daniel" description="我的项目作品集。">
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold mb-2">项目</h1>
        <p class="text-text-muted mb-8">我参与和创建的项目作品。</p>

        <!-- Filter Tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          <button
            class="tag bg-primary text-white cursor-pointer"
            data-filter="all"
          >
            全部
          </button>
          {allTags.map((tag) => (
            <button class="tag cursor-pointer hover:bg-primary hover:text-white transition-colors" data-filter={tag}>
              {tag}
            </button>
          ))}
        </div>

        <!-- Projects Grid -->
        <div class="grid md:grid-cols-2 gap-6" id="projects-grid">
          {projects.map((project) => {
            const s = statusMap[project.data.status] ?? statusMap['in-progress'];
            const c = categoryMap[project.data.category] ?? '个人项目';
            return (
              <a
                href={`/projects/${project.id}`}
                class="card overflow-hidden group block"
                data-tags={project.data.tags.join(',')}
              >
                <div class="aspect-video bg-gradient-to-br from-primary/5 to-primary-light/5 flex items-center justify-center relative overflow-hidden">
                  {project.data.image
                    ? <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                    : <span class="text-5xl font-bold text-primary/15">{project.data.title.charAt(0)}</span>
                  }
                  <div class="absolute top-3 right-3">
                    <span class={`tag text-xs ${s.color}`}>{s.label}</span>
                  </div>
                </div>
                <div class="p-6">
                  <div class="flex flex-wrap gap-2 mb-3">
                    <span class="tag text-xs">{c}</span>
                    {project.data.tags.map((tag) => (
                      <span class="tag text-xs">{tag}</span>
                    ))}
                  </div>
                  <h3 class="font-semibold text-lg mb-2 group-hover:text-primary transition-colors">
                    {project.data.title}
                  </h3>
                  <p class="text-text-muted text-sm leading-relaxed mb-4">
                    {project.data.description}
                  </p>
                  <span class="text-sm text-primary font-medium flex items-center gap-1">
                    查看详情
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll('[data-filter]');
  const projectCards = document.querySelectorAll('#projects-grid > a');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      filterButtons.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white');
      });
      btn.classList.add('bg-primary', 'text-white');

      projectCards.forEach((card) => {
        const tags = card.getAttribute('data-tags') ?? '';
        if (filter === 'all' || tags.split(',').includes(filter!)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
