---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SocialLinks from '../components/SocialLinks.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(({ data }) => data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function estimateReadTime(body: string): string {
  const minutes = Math.ceil(body.length / 400);
  return `${minutes} 分钟`;
}
---

<BaseLayout title="Daniel - 开发者 / 工程师">
  <!-- Hero Section -->
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center md:text-left md:mx-0">
        <div class="flex flex-col md:flex-row items-center gap-8 mb-8">
          <!-- Avatar -->
          <div class="w-28 h-28 rounded-2xl bg-gradient-to-br from-primary to-primary-light flex items-center justify-center text-white text-3xl font-bold shrink-0">
            D
          </div>
          <div>
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
              你好，我是 <span class="gradient-text">Daniel</span>
            </h1>
            <p class="text-text-muted text-lg mt-4 max-w-xl leading-relaxed">
              一名热爱技术的开发者。专注于构建优雅、高效的软件产品，
              乐于分享技术思考和实践经验。
            </p>
          </div>
        </div>
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-4">
          <a href="/about" class="btn-primary">
            了解更多
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/projects" class="btn-secondary">查看项目</a>
          <SocialLinks />
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="section-padding bg-bg-alt">
      <div class="section-container">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold">最新随笔</h2>
          <a href="/blog" class="text-sm text-primary font-medium hover:underline">
            查看全部 &rarr;
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="card p-6 group">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h3 class="font-semibold text-lg group-hover:text-primary transition-colors mb-2">
                {post.data.title}
              </h3>
              <p class="text-text-muted text-sm leading-relaxed mb-4">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between text-xs text-text-muted">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.body && (
                  <span>{estimateReadTime(post.body)}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="section-padding">
      <div class="section-container">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold">精选项目</h2>
          <a href="/projects" class="text-sm text-primary font-medium hover:underline">
            查看全部 &rarr;
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <a href={`/projects/${project.id}`} class="card overflow-hidden group block">
              <div class="aspect-video bg-gradient-to-br from-primary/5 to-primary-light/5 flex items-center justify-center overflow-hidden">
                {project.data.image
                  ? <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                  : <span class="text-4xl font-bold text-primary/20">{project.data.title.charAt(0)}</span>
                }
              </div>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h3 class="font-semibold text-lg mb-2 group-hover:text-primary transition-colors">{project.data.title}</h3>
                <p class="text-text-muted text-sm leading-relaxed">
                  {project.data.description}
                </p>
                <span class="text-sm text-primary font-medium flex items-center gap-1 mt-3">
                  查看详情
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
